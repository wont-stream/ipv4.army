{
	"name": "ipv4.army",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run .",
		"dev": "bun --inspect --watch .",
		"format": "bunx biome format --write",
		"lint": "bunx biome lint --unsafe --write",
		"check": "bunx biome check --unsafe --write",
		"biome": "bun run lint && bun run format && bun run check && git add . && git commit -m 'chore: format and lint'"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.1",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"handlebars": "^4.7.8",
		"html-minifier-terser": "^7.2.0",
		"reconnecting-websocket": "^4.4.0"
	}
}
