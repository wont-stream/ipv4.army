{
	"name": "ipv4.army",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"build": "bun build ./src/web/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/index.ts",
		"lint": "bunx --bun biome check --write"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@prequist/lanyard": "^1.1.0",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@atums/echo": "^2.0.3",
		"@preact/signals": "^2.9.0",
		"badge-maker": "^5.0.2",
		"lucide-preact": "^0.562.0",
		"modern-normalize": "^3.0.1",
		"preact": "^10.29.1",
		"react": "npm:@preact/compat",
		"react-dom": "npm:@preact/compat",
		"sakura.css": "^1.5.1"
	}
}
