	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.1.2",
		"@types/bun": "latest",
		"vitepress": "^1.6.3",
		"vue": "^3.5.17"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"docs:dev": "bunx --bun vitepress dev",
