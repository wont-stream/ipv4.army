{
	"name": "bun-react-template",
	"version": "0.1.0",
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "latest"
	},
	"private": true,
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"build": "bun build ./src/web/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/index.ts",
		"lint": "bunx --bun biome check --write"
	},
	"type": "module",
	"dependencies": {
		"modern-normalize": "^3.0.1",
		"sakura.css": "^1.5.1"
	}
}
